{
  "name": "@verso-js/stores",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "default": "./dist/adapter.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "typecheck": "bunx tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "dependencies": {
    "@verso-js/verso": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@testing-library/react": "^16.3.2",
    "@verso-js/store-adapter-zustand": "workspace:*",
    "jsdom": "^29.0.0",
    "react-dom": "^19.2.4",
    "vitest": "^4.1.0"
  }
}
