{
  "name": "@verso-js/demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "verso dev",
    "build": "verso build",
    "start": "verso start",
    "test:e2e": "bunx playwright test -c playwright.dev.config.ts",
    "test:e2e:smoke": "bunx playwright test -c playwright.dev.config.ts smoke.spec.ts && bunx playwright test -c playwright.prod.config.ts",
    "test:e2e:prod": "bunx playwright test -c playwright.prod.config.ts",
    "test:e2e:all": "bunx playwright test -c playwright.dev.config.ts && bunx playwright test -c playwright.prod.config.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@verso-js/verso": "workspace:*",
    "@verso-js/stores": "workspace:*",
    "@verso-js/store-adapter-zustand": "workspace:*",
    "@verso-js/playwright": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "jotai": "^2.18.1"
  },
  "devDependencies": {
    "vite": "^8.0.0",
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5"
  }
}
