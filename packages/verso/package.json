{
  "name": "@verso-js/verso",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "verso": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-helpers": {
      "types": "./dist/test-helpers.d.ts",
      "default": "./dist/test-helpers.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./defines": "./defines.d.ts"
  },
  "files": [
    "dist",
    "globals.d.ts",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npx vitest run",
    "typecheck": "bunx tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": "^5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/cookie": "^1.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@verso-js/store-adapter-redux": "workspace:*",
    "@verso-js/store-adapter-zustand": "workspace:*",
    "@verso-js/stores": "workspace:*",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.0",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "jiti": "^2.6.1",
    "path-to-regexp": "^8.3.0"
  }
}
